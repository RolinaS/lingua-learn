# ─────────────────────────────────────────────────────────────
# LINGUA-LEARN — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# cp .env.example .env
# ⚠️  Ne jamais committer le fichier .env sur Git
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# ENVIRONNEMENT
# ─────────────────────────────────────────────
NODE_ENV=development
# Valeurs possibles : development | production

# ─────────────────────────────────────────────
# BASE DE DONNÉES — PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lingua_learn_db
POSTGRES_USER=lingua_user
POSTGRES_PASSWORD=change_this_strong_password

# URL complète (utilisée par Prisma/TypeORM)
DATABASE_URL=postgresql://lingua_user:change_this_strong_password@postgres:5432/lingua_learn_db

# ─────────────────────────────────────────────
# BACKEND — Express.js
# ─────────────────────────────────────────────
BACKEND_PORT=5000

# JWT — Générer avec : openssl rand -base64 64
JWT_SECRET=change_this_very_long_and_random_jwt_secret_key
JWT_REFRESH_SECRET=change_this_very_long_and_random_jwt_refresh_secret_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — Origine autorisée pour les requêtes frontend
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────
# FRONTEND — Next.js
# ─────────────────────────────────────────────
FRONTEND_PORT=3000

# Variables publiques exposées côté client (préfixe NEXT_PUBLIC_ obligatoire)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_NAME=LinguaLearn
NEXT_PUBLIC_APP_VERSION=1.0.0
